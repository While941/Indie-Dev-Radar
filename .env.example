# Copy to .env and fill in. Never commit .env.
# GitHub token (optional but recommended — raises search rate limit from 10/min to 30/min)
GH_TOKEN=

# AI provider (OpenAI-compatible). Default: DeepSeek official API.
# Get a key at https://platform.deepseek.com/
AI_API_KEY=
AI_BASE_URL=https://api.deepseek.com

# Feishu (Lark) custom app credentials
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# Target Bitable: app_token + table_id from the multidimensional-table URL
FEISHU_APP_TOKEN=
FEISHU_TABLE_ID=
